{
  "name": "@aldrym/server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "prestart:dev": "corepack pnpm --filter @aldrym/shared build",
    "start:dev": "prisma generate && node scripts/ensure-port-available.mjs && tsx watch src/main.ts",
    "prebuild": "corepack pnpm --filter @aldrym/shared build",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "pretypecheck": "corepack pnpm --filter @aldrym/shared build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@aldrym/shared": "workspace:*",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
