generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  characters   Character[]
}

model Character {
  id                String   @id @default(cuid())
  name              String   @unique
  gender            String
  characterClass    String   @default("knight")
  level             Int      @default(1)
  experience        Int      @default(0)
  health            Int      @default(150)
  maxHealth         Int      @default(150)
  mana              Int      @default(55)
  maxMana           Int      @default(55)
  fistLevel         Int      @default(10)
  fistProgress      Int      @default(0)
  swordLevel        Int      @default(10)
  swordProgress     Int      @default(0)
  axeLevel          Int      @default(10)
  axeProgress       Int      @default(0)
  clubLevel         Int      @default(10)
  clubProgress      Int      @default(0)
  distanceLevel     Int      @default(10)
  distanceProgress  Int      @default(0)
  shieldingLevel    Int      @default(10)
  shieldingProgress Int      @default(0)
  magicLevel        Int      @default(0)
  magicLevelProgress Int     @default(0)
  fishingLevel      Int      @default(10)
  fishingProgress   Int      @default(0)
  foodExpiresAt     DateTime?
  x                 Int      @default(100)
  y                 Int      @default(100)
  z                 Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items             CharacterItem[]

  @@index([userId])
}

model CharacterItem {
  id                  String          @id @default(cuid())
  characterId         String
  itemKey             String
  quantity            Int
  locationType        String          @default("root")
  slotIndex           Int?
  containerItemId     String?
  equipmentSlot       String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  character           Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  containerItem       CharacterItem?  @relation("ContainerContents", fields: [containerItemId], references: [id], onDelete: SetNull)
  containedItems      CharacterItem[] @relation("ContainerContents")

  @@index([characterId])
  @@index([characterId, itemKey])
  @@index([characterId, locationType])
  @@index([characterId, containerItemId])
  @@index([characterId, equipmentSlot])
}

model Monster {
  id               String   @id
  name             String   @unique
  level            Int
  maxHealth        Int
  experienceReward Int
  respawnMs        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
